{
  "display_information": {
    "name": "SjangLab Infra Alerts",
    "description": "Alert delivery app for SjangLab infrastructure monitoring"
  },
  "features": {
    "bot_user": {
      "display_name": "infra-alerts",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "incoming-webhook"
      ]
    }
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
